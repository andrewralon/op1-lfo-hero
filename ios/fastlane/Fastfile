default_platform(:ios)

platform :ios do
  before_all do
    app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_CONNECT_KEY_PATH"],
      duration: 1200,
      in_house: false
    )
  end

  desc "Sync certificates and provisioning profiles to ~/Library/MobileDevice"
  lane :certs do
    match(type: "development")
    match(type: "appstore")
  end

  desc "Capture App Store screenshots on simulators"
  lane :screenshots do
    capture_screenshots(
      project: "op1-lfo-hero.xcodeproj",
      scheme: "op1-lfo-hero",
      output_directory: "./fastlane/screenshots",
      clear_previous_screenshots: true,
      skip_open_summary: true,
      html_template: "./fastlane/screenshots_template.html.erb"
    )
    frame_screenshots(
      path: "./fastlane/screenshots"
    )
    sh("open ./screenshots/screenshots.html")
  end

  desc "Preview what the next beta changelog would look like"
  lane :whatif do
    commits = changelog_from_git_commits(
      merge_commit_filtering: "exclude_merges",
      pretty: "- %s"
    )
    UI.message(commits)
  end

  desc "Print commits since a beta build number: fastlane changelog since:7"
  lane :changelog do |options|
    since = options[:since] || UI.input("Since build number: ")
    notes = changelog_from_git_commits(
      between: ["beta/#{since}", "HEAD"],
      merge_commit_filtering: "exclude_merges",
      pretty: "- %s"
    )
    UI.message(notes)
  end

  desc "Build and upload to TestFlight"
  lane :beta do |options|
    match(type: "appstore", readonly: true)
    increment_build_number(xcodeproj: "op1-lfo-hero.xcodeproj")
    build_app(
      project: "op1-lfo-hero.xcodeproj",
      scheme: "op1-lfo-hero",
      export_method: "app-store"
    )
    commit_options = { merge_commit_filtering: "exclude_merges", pretty: "- %s" }
    commit_options[:between] = ["beta/#{options[:since]}", "HEAD"] if options[:since]
    commits = changelog_from_git_commits(commit_options)
    upload_to_testflight(
      skip_waiting_for_build_processing: true,
      changelog: <<~NOTES
        o hai beta tester!
        -unless you have an op1, there's no audio
        -test all UI components - do they do what you expect? slide, change, ...
        -does it look good visually? is anything skewed or morphed? a non-round circle, etc
        -how fast does it open? should be ~3 seconds after clicking to respond like normal. try 2-3 times pls.
        -are the UI elements big enough?
        -is anything weird? does anything *not* do what you expect?

        commits:
        #{commits}
      NOTES
    )
    add_git_tag(
      tag: "beta/#{get_build_number(xcodeproj: "op1-lfo-hero.xcodeproj")}"
    )
    push_git_tags
  end

  desc "Full release: build + upload metadata + screenshots + submit for review"
  lane :release do
    match(type: "appstore", readonly: true)
    increment_build_number(xcodeproj: "op1-lfo-hero.xcodeproj")
    build_app(
      project: "op1-lfo-hero.xcodeproj",
      scheme: "op1-lfo-hero",
      export_method: "app-store"
    )
    deliver(
      submit_for_review: true,
      automatic_release: false,
      force: true,
      precheck_include_in_app_purchases: false
    )
  end
end
